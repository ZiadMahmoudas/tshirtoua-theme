{% comment %} templates/product.liquid {% endcomment %}

<div class="container">
  <div class="product-layout">

    {% comment %} ── GALLERY ── {% endcomment %}
    <div class="product-gallery">
      <div class="product-gallery__main">
        <img
          id="product-main-img"
          src="{{ product.featured_image | img_url: '800x1000' }}"
          alt="{{ product.title | escape }}"
          width="800" height="1000">
      </div>
      {% if product.images.size > 1 %}
        <div class="product-gallery__thumbs">
          {% for image in product.images %}
            <div class="product-gallery__thumb {% if forloop.first %}active{% endif %}"
                 data-src="{{ image | img_url: '800x1000' }}">
              <img src="{{ image | img_url: '150x150' }}" alt="{{ product.title }} - صورة {{ forloop.index }}" loading="lazy">
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {% comment %} ── PRODUCT INFO ── {% endcomment %}
    <div class="product-info">

      {% comment %} Breadcrumb {% endcomment %}
      <div class="product-breadcrumb">
        <a href="/">الرئيسية</a>
        <span>›</span>
        <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        <span>›</span>
        {{ product.title }}
      </div>

      <h1 class="product-title">{{ product.title }}</h1>

      {% comment %} Price {% endcomment %}
      <div class="product-price-section">
        {% if product.price == 0 %}
          <div class="product-price" style="color:var(--success);">مجاني للتجربة</div>
        {% else %}
          <div class="product-price">{{ product.price | money }}</div>
          {% if product.compare_at_price > product.price %}
            <div class="product-price-compare">{{ product.compare_at_price | money }}</div>
            {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
            <div class="product-discount-badge">وفرت {{ discount }}%</div>
          {% endif %}
        {% endif %}
      </div>

      {% comment %} Color variants {% endcomment %}
      {% assign color_option = product.options_by_name['Color'] | default: product.options_by_name['اللون'] %}
      {% if color_option %}
        <div>
          <p class="product-section-label">اللون — <span style="color:var(--text);font-weight:400;">{{ color_option.selected_value }}</span></p>
          <div class="color-swatches">
            {% for value in color_option.values %}
              {% assign swatch_color = value | downcase | replace: ' ', '' %}
              <div class="color-swatch {% if forloop.first %}active{% endif %}"
                   style="background:{{ swatch_color }};"
                   title="{{ value }}"
                   data-value="{{ value }}">
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {% comment %} Size variants {% endcomment %}
      {% assign size_option = product.options_by_name['Size'] | default: product.options_by_name['المقاس'] %}
      {% if size_option %}
        <div>
          <p class="product-section-label">المقاس</p>
          <div class="size-grid">
            {% for variant in product.variants %}
              <div class="size-option {% unless variant.available %}unavailable{% endunless %} {% if forloop.first and variant.available %}active{% endif %}"
                   data-variant-id="{{ variant.id }}"
                   data-size="{{ variant.title }}">
                {{ variant.title | replace: ' / Default Title', '' }}
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {% comment %} Qty {% endcomment %}
      <p class="product-section-label">الكمية</p>
      <div class="qty-selector">
        <button id="qty-minus" type="button">−</button>
        <input type="number" id="product-qty" value="1" min="1" max="99" readonly>
        <button id="qty-plus" type="button">+</button>
      </div>

      {% comment %} Add to cart {% endcomment %}
      <div class="product-add-actions">
        <button
          id="add-to-cart-btn"
          class="btn btn-primary"
          data-add-to-cart
          data-variant-id="{{ product.first_available_variant.id }}"
          {% unless product.available %}disabled{% endunless %}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          {% if product.available %}أضف للعربة{% else %}نفدت الكمية{% endif %}
        </button>
        <button class="wishlist-btn btn btn-outline btn-icon" style="width:50px;border-radius:var(--radius-sm);" aria-label="المفضلة">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </button>
      </div>

      {% comment %} Description {% endcomment %}
      {% if product.description != blank %}
        <div class="divider"></div>
        <div style="font-size:.9rem;color:var(--text-muted);line-height:1.8;">
          {{ product.description }}
        </div>
      {% endif %}

      {% comment %} Meta {% endcomment %}
      <div class="product-meta">
        <div class="product-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
            <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          <span>شحن سريع <strong>2-4 أيام عمل</strong></span>
        </div>
        <div class="product-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/>
          </svg>
          <span>استرجاع مجاني <strong>خلال 14 يوم</strong></span>
        </div>
        <div class="product-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <span>دفع آمن <strong>Visa, Mastercard, Fawry</strong></span>
        </div>
        {% if product.metafields.custom.made_in != blank %}
          <div class="product-meta-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            <span>صُنع في <strong>{{ product.metafields.custom.made_in }}</strong></span>
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</div>

{% comment %} ── Related products ── {% endcomment %}
{% if product.collections.first.products.size > 1 %}
<section class="section" style="padding-top:0;">
  <div class="container">
    <div class="section-header">
      <p class="section-label">ممكن يعجبك</p>
      <h2 class="section-title">منتجات مشابهة</h2>
    </div>
    <div class="grid grid-4">
      {% for related in product.collections.first.products limit: 4 %}
        {% unless related.id == product.id %}
          {% render 'product-card', product: related %}
        {% endunless %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

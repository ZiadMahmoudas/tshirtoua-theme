{% comment %} templates/customers/login.liquid {% endcomment %}

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-card__logo">تشيرت<span style="color:var(--text)">وا</span></div>
    <p class="auth-card__tagline">أهلاً بيك — سجل دخولك</p>

    <h2 class="auth-card__title">تسجيل الدخول</h2>

    {% if form.errors %}
      <div style="background:rgba(255,69,69,.1);border:1px solid var(--danger);border-radius:var(--radius-sm);padding:12px;margin-bottom:16px;font-size:.875rem;color:var(--danger);">
        ⚠️ {{ form.errors | default_errors }}
      </div>
    {% endif %}

    {% comment %} Shopify native form (works without JS) {% endcomment %}
    {% form 'customer_login', id: 'login-form' %}
      <div class="form-group">
        <label class="form-label" for="customer_email">البريد الإلكتروني</label>
        <input
          class="form-input"
          type="email"
          id="customer_email"
          name="customer[email]"
          autocomplete="email"
          placeholder="example@email.com"
          required>
      </div>

      <div class="form-group">
        <label class="form-label" for="customer_password">كلمة السر</label>
        <div class="input-group">
          <input
            class="form-input"
            type="password"
            id="customer_password"
            name="customer[password]"
            autocomplete="current-password"
            placeholder="أدخل كلمة السر"
            style="padding-left:44px;"
            required>
          <span class="input-toggle" role="button" tabindex="0">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </span>
        </div>
      </div>

      <div style="text-align:left;margin-bottom:20px;">
        <a href="/account/login#recover" style="font-size:.8rem;color:var(--accent);">نسيت كلمة السر؟</a>
      </div>

      <button type="submit" class="btn btn-primary btn-full btn-lg">
        دخول
      </button>
    {% endform %}

    <div class="divider"></div>

    {% comment %} Recover password form {% endcomment %}
    <div id="recover" style="display:none;" class="recover-form">
      {% form 'recover_customer_password' %}
        <p style="font-size:.875rem;color:var(--text-muted);margin-bottom:16px;">هنبعتلك إيميل لإعادة تعيين كلمة السر</p>
        <div class="form-group">
          <label class="form-label" for="recover_email">البريد الإلكتروني</label>
          <input class="form-input" type="email" name="email" id="recover_email" placeholder="example@email.com" required>
        </div>
        <button type="submit" class="btn btn-outline btn-full">إرسال رابط الاسترداد</button>
      {% endform %}
    </div>

    <div class="auth-footer">
      مش عندك حساب؟ <a href="/account/register">سجل دلوقتي</a>
    </div>
  </div>
</div>

<script>
  // Toggle recover form
  if (window.location.hash === '#recover') {
    document.querySelector('.recover-form').style.display = 'block';
    document.getElementById('login-form').style.display = 'none';
  }
</script>

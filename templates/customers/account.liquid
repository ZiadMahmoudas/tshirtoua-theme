{% comment %} templates/customers/account.liquid {% endcomment %}

<div class="container">
  <div class="account-layout">

    {% comment %} Sidebar {% endcomment %}
    <aside class="account-sidebar">
      <div class="account-sidebar__user">
        <div class="account-avatar">
          {{ customer.first_name | slice: 0 | upcase }}
        </div>
        <div class="account-name">{{ customer.name }}</div>
        <div class="account-email">{{ customer.email }}</div>
      </div>
      <nav class="account-nav">
        <a href="/account" class="active">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
          لوحة التحكم
        </a>
        <a href="/account/orders">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          طلباتي
        </a>
        <a href="/account/addresses">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          عناويني
        </a>
        <a href="/account/logout" style="margin-top:8px;color:var(--danger);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          خروج
        </a>
      </nav>
    </aside>

    {% comment %} Content {% endcomment %}
    <main class="account-content">
      <h2 class="account-content__title">
        أهلاً بيك {{ customer.first_name }}! 👋
      </h2>

      {% comment %} Stats {% endcomment %}
      <div class="grid grid-3" style="gap:16px;margin-bottom:32px;">
        <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-sm);padding:20px;text-align:center;">
          <div style="font-family:var(--font-display);font-size:2rem;color:var(--accent);">{{ customer.orders_count }}</div>
          <div style="font-size:.8rem;color:var(--text-muted);">طلباتك</div>
        </div>
        <div style="background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius-sm);padding:20px;text-align:center;">
          <div style="font-family:var(--font-display);font-size:2rem;color:var(--accent);">{{ customer.total_spent | money_without_currency }}</div>
          <div style="font-size:.8rem;color:var(--text-muted);">إجمالي مشترياتك</div>
        </div>
        <div style="background:var(--accent-dim);border:1px solid rgba(232,255,0,.2);border-radius:var(--radius-sm);padding:20px;text-align:center;">
          <div style="font-size:1.5rem;">⭐</div>
          <div style="font-size:.8rem;color:var(--accent);font-weight:700;margin-top:4px;">عميل مميز</div>
        </div>
      </div>

      {% comment %} Recent orders {% endcomment %}
      <h3 style="font-size:1rem;font-weight:700;margin-bottom:16px;">آخر الطلبات</h3>

      {% if customer.orders.size > 0 %}
        {% for order in customer.orders limit: 5 %}
          <div class="order-card">
            <div class="order-card__header">
              <div>
                <div class="order-number">طلب #{{ order.order_number }}</div>
                <div class="order-date">{{ order.created_at | date: '%d %B %Y' }}</div>
              </div>
              <div style="display:flex;align-items:center;gap:10px;">
                {% case order.financial_status %}
                  {% when 'paid' %}
                    <span class="order-status status-paid">✓ مدفوع</span>
                  {% when 'pending' %}
                    <span class="order-status status-pending">⏳ قيد الانتظار</span>
                  {% when 'refunded' %}
                    <span class="order-status status-canceled">↩ مسترجع</span>
                  {% else %}
                    <span class="order-status status-pending">{{ order.financial_status }}</span>
                {% endcase %}
                {% if order.fulfillment_status == 'fulfilled' %}
                  <span class="order-status status-shipped">🚚 شُحن</span>
                {% endif %}
              </div>
            </div>
            <div style="font-size:.875rem;color:var(--text-muted);">
              {{ order.line_items | map: 'title' | join: '، ' }}
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:10px;">
              <span style="font-weight:700;color:var(--accent);">{{ order.total_price | money }}</span>
              <a href="{{ order.customer_url }}" class="btn btn-ghost btn-sm">عرض التفاصيل →</a>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div class="empty-state" style="padding:40px 20px;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
          </svg>
          <h3>لسه ماشترتيش</h3>
          <p>ابدأ التسوق دلوقتي واكتشف أجمل الكوليكشنز</p>
          <a href="/collections/all" class="btn btn-primary">تسوق دلوقتي</a>
        </div>
      {% endif %}

    </main>
  </div>
</div>

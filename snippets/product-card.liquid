{% comment %}
  snippets/product-card.liquid
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

{% assign default_variant = product.first_available_variant | default: product.variants.first %}
{% assign is_on_sale = false %}
{% if product.compare_at_price > product.price %}
  {% assign is_on_sale = true %}
{% endif %}

{% assign season_tag = '' %}
{% for tag in product.tags %}
  {% if tag == 'summer' or tag == 'winter' or tag == 'autumn' or tag == 'casual' %}
    {% assign season_tag = tag %}
    {% break %}
  {% endif %}
{% endfor %}

{% assign thirty_days_ago = now | date: '%s' | minus: 2592000 %}

<div class="product-card fade-in"
     data-season="{{ season_tag }}"
     data-product-id="{{ product.id }}">

  <a href="{{ product.url }}" class="product-card__media">
    {% if product.featured_image %}
      <img
        src="{{ product.featured_image | img_url: '600x750' }}"
        alt="{{ product.title | escape }}"
        loading="lazy"
        width="600" height="750">
    {% else %}
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;background:var(--bg-elevated);">👕</div>
    {% endif %}

  {% comment %} تاج 'جديد' - لو المنتج اتعمل في آخر 30 يوم {% endcomment %}
  {% if product_created_seconds > thirty_days_ago %}
    <span class="badge-pill badge-new">جديد</span>
  {% endif %}

  {% comment %} تاج الخصم {% endcomment %}
  {% if is_on_sale %}
    <span class="badge-pill badge-sale">-{{ discount_percentage }}%</span>
  {% endif %}

  {% comment %} تاج الفصل (صيفي/شتوي/خريفي/كاجوال) {% endcomment %}
  {% if season_tag != '' %}
    <span class="badge-pill badge-season">
      {% case season_tag %}
        {% when 'summer' %}☀️ صيفي
        {% when 'winter' %}❄️ شتوي
        {% when 'autumn' %}🍂 خريفي
        {% when 'casual' %}👕 كاجوال
      {% endcase %}
    </span>
  {% endif %}

</div>

    {% comment %} Wishlist {% endcomment %}
    <button class="wishlist-btn" aria-label="إضافة للمفضلة">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>

    {% comment %} Quick Add {% endcomment %}
    <div class="product-card__quick-add">
      <button
        class="btn btn-primary btn-full btn-sm"
        data-quick-add
        data-variant-id="{{ default_variant.id }}"
        data-title="{{ product.title | escape }}">
        + أضف للعربة
      </button>
    </div>
  </a>

  <div class="product-card__info">
    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    <p class="product-card__season">
      {% if season_tag == 'summer' %}تشيرت صيفي
      {% elsif season_tag == 'winter' %}تشيرت شتوي
      {% elsif season_tag == 'autumn' %}تشيرت خريفي
      {% elsif season_tag == 'casual' %}بنطلون كاجوال
      {% else %}{{ product.type }}
      {% endif %}
    </p>
    <div class="product-card__price">
      {% if product.price == 0 %}
        <span class="price-current price-free">مجاني للتجربة</span>
      {% else %}
        <span class="price-current">{{ product.price | money }}</span>
        {% if is_on_sale %}
          <span class="price-original">{{ product.compare_at_price | money }}</span>
        {% endif %}
      {% endif %}
    </div>
  </div>
</div>
